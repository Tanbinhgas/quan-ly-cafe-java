<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quanlycafe.controller.LoginController"
      style="-fx-background-color:#f4f6f9;">

    <Label text="CAFE MANAGER"
           style="-fx-font-size:67; -fx-font-weight:bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Tài khoản:" 
               prefWidth="100"
               style="-fx-font-size:16;"/>
        <TextField fx:id="txtUser" 
                   prefWidth="300"
                   prefHeight="30"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Mật khẩu:" 
               prefWidth="100"
               style="-fx-font-size:16;"/>
        <PasswordField fx:id="txtPass" 
                       prefWidth="300" 
                       prefHeight="30"/>
    </HBox>

    <Button text="Đăng nhập"
            prefWidth="220"
            prefHeight="25"
            onAction="#login"
            defaultButton="true"
            style="-fx-font-size:16;
                   -fx-background-color:#2ecc71;
                   -fx-text-fill:white;
                   -fx-font-weight:bold;"/>

    <Button text="Thoát"
            prefWidth="220"
            prefHeight="25"
            cancelButton="true"
            onAction="#exit"
            style="-fx-background-color:#e74c3c;
                   -fx-text-fill:white;
                   -fx-font-weight:bold;
                   -fx-font-size:16;"/>

    <Label fx:id="lblMessage"
           textFill="red"/>

</VBox>