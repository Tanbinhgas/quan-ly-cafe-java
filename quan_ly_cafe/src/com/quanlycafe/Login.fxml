<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quanlycafe.controller.LoginController"
            prefWidth="900" prefHeight="560"
            style="-fx-background-color:#1a2634;">

    <left>
        <StackPane prefWidth="420" prefHeight="560"
                   style="-fx-background-color:#1a2634;">
            <VBox alignment="CENTER" spacing="18">
                <padding>
                    <Insets top="0" right="40" bottom="0" left="40"/>
                </padding>

                <Label text="☕"
                       style="-fx-font-size:72;"/>

                <Label text="CAFE MANAGER"
                       style="-fx-font-size:28; -fx-font-weight:bold;
                              -fx-text-fill:#f0c040;
                              -fx-effect:dropshadow(gaussian,#000000aa,8,0,0,2);"/>

                <Label text="Hệ thống quản lý quán cà phê"
                       style="-fx-font-size:13; -fx-text-fill:#8fa8c0;
                              -fx-text-alignment:center;"
                       wrapText="true"/>

                <HBox alignment="CENTER" spacing="8">
                    <Line startX="0" endX="50"
                          style="-fx-stroke:#3d5166; -fx-stroke-width:1;"/>
                    <Label text="●"
                           style="-fx-text-fill:#f0c040; -fx-font-size:8;"/>
                    <Line startX="0" endX="50"
                          style="-fx-stroke:#3d5166; -fx-stroke-width:1;"/>
                </HBox>
            </VBox>
        </StackPane>
    </left>

    <center>
        <StackPane style="-fx-background-color:white;
                          -fx-background-radius:16 0 0 16;">
            <VBox alignment="CENTER" spacing="20" maxWidth="340">
                <padding>
                    <Insets top="0" right="50" bottom="0" left="50"/>
                </padding>

                <VBox spacing="6" alignment="CENTER">
                    <Label text="Đăng nhập"
                           style="-fx-font-size:26; -fx-font-weight:bold;
                                  -fx-text-fill:#1a2634;"/>
                    <Label text="Vui lòng nhập thông tin tài khoản"
                           style="-fx-font-size:12; -fx-text-fill:#95a5a6;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Tài khoản"
                           style="-fx-font-size:13; -fx-font-weight:bold;
                                  -fx-text-fill:#2c3e50;"/>
                    <TextField fx:id="txtUser"
                               promptText="Nhập tên đăng nhập..."
                               prefHeight="42" maxWidth="Infinity"
                               style="-fx-background-color:#f4f6f9;
                                      -fx-border-color:#dde1e7;
                                      -fx-border-radius:8;
                                      -fx-background-radius:8;
                                      -fx-font-size:13;
                                      -fx-padding:0 12 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Mật khẩu"
                           style="-fx-font-size:13; -fx-font-weight:bold;
                                  -fx-text-fill:#2c3e50;"/>
                    <PasswordField fx:id="txtPass"
                                   promptText="Nhập mật khẩu..."
                                   prefHeight="42" maxWidth="Infinity"
                                   style="-fx-background-color:#f4f6f9;
                                          -fx-border-color:#dde1e7;
                                          -fx-border-radius:8;
                                          -fx-background-radius:8;
                                          -fx-font-size:13;
                                          -fx-padding:0 12 0 12;"/>
                </VBox>

                <Label fx:id="lblMessage" text=""
                       style="-fx-text-fill:#e74c3c; -fx-font-size:12;"
                       wrapText="true"/>

                <Button text="🔐  Đăng nhập"
                        prefHeight="44" maxWidth="Infinity"
                        onAction="#login"
                        defaultButton="true"
                        style="-fx-background-color:#1a2634;
                               -fx-text-fill:#f0c040;
                               -fx-font-weight:bold;
                               -fx-font-size:14;
                               -fx-background-radius:8;
                               -fx-cursor:hand;"/>

                <Button text="Thoát"
                        prefHeight="38" maxWidth="Infinity"
                        onAction="#exit"
                        cancelButton="true"
                        style="-fx-background-color:transparent;
                               -fx-text-fill:#95a5a6;
                               -fx-font-size:13;
                               -fx-border-color:#dde1e7;
                               -fx-border-radius:8;
                               -fx-background-radius:8;
                               -fx-cursor:hand;"/>

                <Label text="Demo: admin / 123"
                       style="-fx-text-fill:#bdc3c7; -fx-font-size:11;"/>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
