<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quanlycafe.controller.TableController"
      spacing="16"
      VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Quản lý bàn"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#2e7d32;"/>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label text="●" style="-fx-text-fill:#27ae60; -fx-font-size:18;"/>
        <Label text="Trống"/>
        <Label text="●" style="-fx-text-fill:#e74c3c; -fx-font-size:18;"/>
        <Label text="Có khách"/>
        <Label text="●" style="-fx-text-fill:#f39c12; -fx-font-size:18;"/>
        <Label text="Đặt trước"/>
    </HBox>

    <Separator/>

    <StackPane VBox.vgrow="ALWAYS" alignment="CENTER">
        <GridPane fx:id="tableGrid"
                  hgap="20"
                  vgap="20"
                  alignment="CENTER"/>
    </StackPane>

</VBox>
