<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" prefWidth="420"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quanlycafe.controller.NguyenLieuFormController">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <GridPane hgap="12" vgap="10">
        <Label text="Mã nguyên liệu:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtMaNguyenLieu" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="240"/>

        <Label text="Tên nguyên liệu:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtTenNguyenLieu" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Đơn vị tính:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight:bold;"/>
        <ComboBox fx:id="cboDonViTinh" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="240"/>

        <Label text="Số lượng tồn:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtSoLuongTon" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Tối thiểu:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtSoLuongToiThieu" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Ngày cập nhật:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtNgayCapNhat" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Ghi chú:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight:bold;"/>
        <TextArea fx:id="txtGhiChu" GridPane.columnIndex="1" GridPane.rowIndex="6" prefHeight="70" wrapText="true"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnLuu" text="💾 Lưu" onAction="#handleLuu"
                style="-fx-background-color:#2ecc71; -fx-text-fill:white; -fx-font-weight:bold;
                       -fx-background-radius:6; -fx-padding:6 18 6 18;"/>
        <Button fx:id="btnHuy" text="✖ Hủy" onAction="#handleHuy"
                style="-fx-background-color:#95a5a6; -fx-text-fill:white; -fx-font-weight:bold;
                       -fx-background-radius:6; -fx-padding:6 18 6 18;"/>
    </HBox>
</VBox>